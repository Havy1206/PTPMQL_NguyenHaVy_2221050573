@model IEnumerable<DemoMVC.Models.StudentVM>

@{
    ViewData["Title"] = "Danh sách Sinh viên";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">QUẢN LÝ DANH SÁCH SINH VIÊN</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Nhập dữ liệu từ Excel</h5>
        </div>
        <div class="card-body">
            <form asp-action="Import" asp-controller="Student" method="post" enctype="multipart/form-data" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-auto">
                    <input type="file" name="file" class="form-control" accept=".xlsx, .xls" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-file-earmark-excel"></i> Tải lên & Import
                    </button>
                </div>
                <div class="col-auto">
                    <a href="/Student/Create" class="btn btn-outline-primary">Thêm thủ công</a>
                </div>
            </form>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mt-3 mb-0">
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mt-3 mb-0">
                    @TempData["Error"]
                </div>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Mã SV</th>
                        <th>Họ tên</th>
                        <th>Tuổi</th>
                        <th>Khoa</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.StudentCode</td>
                                <td>@item.FullName</td>
                                <td>@item.Age</td>
                                <td>@item.FacultyName</td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.StudentCode" class="btn btn-sm btn-warning">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.StudentCode" class="btn btn-sm btn-danger">Xóa</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">Chưa có dữ liệu sinh viên.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>