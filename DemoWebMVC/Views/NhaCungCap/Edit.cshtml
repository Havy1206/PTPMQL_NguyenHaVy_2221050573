@model DemoMVC.Models.Entities.NhaCungCap
@{ ViewData["Title"] = "Sửa Nhà cung cấp"; }

<div class="container mt-4">
    <h2>Sửa thông tin Nhà cung cấp</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="TenNCC" class="control-label"></label>
                    <input asp-for="TenNCC" class="form-control" />
                    <span asp-validation-for="TenNCC" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SoDienThoai" class="control-label"></label>
                    <input asp-for="SoDienThoai" class="form-control" />
                    <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="DiaChi" class="control-label"></label>
                    <input asp-for="DiaChi" class="form-control" />
                    <span asp-validation-for="DiaChi" class="text-danger"></span>
                </div>
                <div class="mb-3 mt-4">
                    <input type="submit" value="Cập nhật" class="btn btn-warning" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>