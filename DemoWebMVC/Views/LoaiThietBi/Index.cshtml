@model IEnumerable<DemoMVC.Models.Entities.LoaiThietBi>
@{ ViewData["Title"] = "Loại thiết bị"; }

<div class="container mt-4">
    <h2>Danh sách Loại thiết bị</h2>
    
    <div class="d-flex justify-content-between mb-3">
        <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
        
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Tìm tên loại..." />
            <button type="submit" class="btn btn-outline-success">Tìm kiếm</button>
        </form>
    </div>

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên Loại Thiết Bị</th> 
                <th>Mô Tả</th>
                <th class="text-center" style="width: 200px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.TenLoai</td> 
                        <td>@item.MoTa</td> 
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Chi tiết</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">Không tìm thấy dữ liệu.</td>
                </tr>
            }
        </tbody>
    </table>
</div>