@model IEnumerable<DemoMVC.Models.Entities.Product>
<h2>Quản lý sản phẩm</h2>
<p><a asp-action="Create" class="btn btn-primary">Thêm sản phẩm mới</a></p>
<table class="table">
    <thead>
        <tr>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.Price.ToString("N0") VNĐ</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProductID" class="btn btn-warning btn-sm">Sửa</a> |
                <a asp-action="Delete" asp-route-id="@item.ProductID" class="btn btn-danger btn-sm">Xóa</a>
            </td>
        </tr>
    }
    </tbody>
</table>