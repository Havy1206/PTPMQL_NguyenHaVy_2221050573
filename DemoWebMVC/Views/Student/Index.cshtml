@{
    ViewData["Title"] = "Danh sách Sinh viên";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">QUẢN LÝ DANH SÁCH SINH VIÊN</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Nhập dữ liệu từ Excel</h5>
        </div>
        <div class="card-body">
            <form asp-action="Import" asp-controller="Student" method="post" enctype="multipart/form-data" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-auto">
                    <input type="file" name="file" class="form-control" accept=".xlsx, .xls" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-file-earmark-excel"></i> Tải lên & Import
                    </button>
                </div>
                <div class="col-auto">
                    <button type="button" id="btnAddStudent" class="btn btn-outline-primary">Thêm thủ công</button>
                </div>
            </form>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mt-3 mb-0">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger mt-3 mb-0">@TempData["Error"]</div>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body" id="studentTableContainer">
            <div class="text-center">
                <div class="spinner-border text-primary" role="status"></div>
                <p>Đang tải dữ liệu sinh viên...</p>
            </div>
        </div>
    </div>
</div>

<div id="modalContainer"></div>

@section Scripts {
    <script src="~/js/Student/student.js"></script>
    <script src="~/js/Student/student-table.js"></script>
    <script src="~/js/Student/student-create.js"></script>
    <script src="~/js/Student/student-edit.js"></script>
    <script src="~/js/Student/student-delete.js"></script>
}