@model IEnumerable<DemoMVC.Models.Entities.ThietBi>

<div class="container mt-4">
    <h2>Quản Lý Thiết Bị</h2>
    <div class="d-flex justify-content-between mb-3">
        <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Tìm tên thiết bị..." />
            <button type="submit" class="btn btn-success">Tìm</button>
        </form>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tên TB</th>
                <th>Loại</th>
                <th>Nhà Cung Cấp</th>
                <th>Giá</th>
                <th>Tồn Kho</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>@item.TenTB</td>
                    <td>@item.LoaiThietBi?.TenLoai</td>
                    <td>@item.NhaCungCap?.TenNCC</td>
                    <td>@item.DonGia.ToString("N0") đ</td>
                    <td>@item.SoLuongTon</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Xem</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>