@model DemoMVC.ViewModels.PagedResult<DemoMVC.Models.StudentVM>
    @{
    if (Model == null) return; // Nếu Model null thì không chạy tiếp code bên dưới
}

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Mã SV</th>
            <th>Họ tên</th>
            <th>Tuổi</th>
            <th>Khoa</th>
            <th class="text-center">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.StudentCode</td>
                    <td>@item.FullName</td>
                    <td>@item.Age</td>
                    <td>@item.FacultyName</td>
                    <td class="text-center">
                        <a href="/Student/Edit/@item.StudentCode" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="/Student/Delete/@item.StudentCode" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">Chưa có dữ liệu sinh viên.</td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="text-muted">
        Trang !@Model!.CurrentPage / @(Math.Ceiling((double)Model.TotalItems / Model.PageSize)) 
        (Tổng: @Model.TotalItems sinh viên)
    </div>
    <nav>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:void(0)" onclick="loadStudents(@(Model.CurrentPage - 1))">Trước</a>
            </li>
            
            <li class="page-item @(Model.CurrentPage * Model.PageSize >= Model.TotalItems ? "disabled" : "")">
                <a class="page-link" href="javascript:void(0)" onclick="loadStudents(@(Model.CurrentPage + 1))">Sau</a>
            </li>
        </ul>
    </nav>
</div>