@model DemoMVC.Models.Entities.LoaiThietBi
@{ ViewData["Title"] = "Xóa Loại thiết bị"; }

<div class="container mt-4">
    <h2 class="text-danger">Xóa Loại thiết bị</h2>
    <h3>Bạn có chắc chắn muốn xóa loại thiết bị này không?</h3>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Tên Loại Thiết Bị</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.TenLoai)</dd>
        
        <dt class="col-sm-3">Mô Tả</dt>
        <dd class="col-sm-9">@Html.DisplayFor(model => model.MoTa)</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa ngay" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary ms-2">Hủy bỏ</a>
    </form>
</div>